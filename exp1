const express = require('express');
const app = express();
const port = 3000;
app.use(express.json());

app.get('/', (req, res) => {
    res.json({ message: 'Hello World!' });
});
app.post('/echo', (req, res) => {
    const body=req.body;
    res.json({received: body});

});
app.listen(port, () => {
  console.log(`Server is running on http://localhost:${port}`);
});

